#Empower ability
#First characters
execute if entity @s[scores={kit=1..31}] run function du-in:kit/nick/ability/empower
#Judy, Susie, Knight, Jevil & Bogo
execute if entity @s[scores={kit=35..40}] run function du-in:kit/nick/ability/empower
#Saac
execute if entity @s[scores={kit=1000}] run function du-in:kit/nick/ability/empower
#Jerma
execute if entity @s[scores={kit=1003}] run function du-in:kit/nick/ability/empower